# ForkHub environment variables
# Copy to .env and fill in your values.
# Env vars override forkhub.toml settings.

# GitHub personal access token (required for API access)
GITHUB_TOKEN=

# Anthropic auth — use ONE of the following:
# Option 1: Anthropic API key (direct)
ANTHROPIC_API_KEY=
# Option 2: OAuth token from `claude set-token`
CLAUDE_ACCESS_TOKEN=
